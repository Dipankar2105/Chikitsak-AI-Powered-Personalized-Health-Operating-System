# ── App ──────────────────────────────────────────────────────────────────
APP_NAME=Chikitsak API
APP_DESCRIPTION=AI Powered Personalized Health Operating System
APP_VERSION=0.3.0
ENVIRONMENT=development
DEBUG=true

# ── Database ─────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./chikitsak.db

# ── CORS ─────────────────────────────────────────────────────────────────
# Accepts JSON list or comma-separated origins.
# Development: ["*"]
# Production:  https://app.chikitsak.com,https://admin.chikitsak.com
CORS_ORIGINS=["*"]

# ── Logging ──────────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG
# ── OpenRouter LLM (Fallback AI) ──────────────────────────────────────────
# Get your API key from: https://openrouter.ai/
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here
OPENROUTER_MODEL=openrouter/auto

# ── Email / MailBluster ───────────────────────────────────────────────────
# Get your API key from: https://mailbluster.com/
# Your API Key: 4d9ed95d-ebc9-4892-a58a-737670c224e0
MAILBLUSTER_API_KEY=4d9ed95d-ebc9-4892-a58a-737670c224e0
EMAIL_FROM_ADDRESS=noreply@chikitsak.ai
EMAIL_FROM_NAME=Chikitsak AI
FRONTEND_URL=http://localhost:3000
PASSWORD_RESET_TOKEN_EXPIRE_HOURS=1

# ── ML Model Configuration ────────────────────────────────────────────────
LLM_CONFIDENCE_THRESHOLD=0.65
LLM_TIMEOUT=30
ML_MODEL_TIMEOUT=10
GPU_ENABLED=false